    {
      "parameters": {
        "jsCode": "const raw = ($input.first().json.queue || '').trim();\n\nconst normalize = (s) => s\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nlet cleaned = normalize(raw.toLowerCase());\n\n// aceita separadores como hífen ou barra\ncleaned = cleaned.replace(/\\s*[-\\/|]\\s*/g, ',');\ncleaned = cleaned.replace(/\\s*,\\s*/g, ',');\n\nlet city = cleaned;\nlet uf = '';\n\nif (!cleaned.includes(',')) {\n  const m = cleaned.match(/^(.*)\\s([a-z]{2})$/i);\n  if (m) {\n    cleaned = `${m[1].trim()},${m[2].trim()}`;\n  }\n}\n\nif (cleaned.includes(',')) {\n  const parts = cleaned.split(',').map(p => p.trim()).filter(Boolean);\n  city = parts[0] || '';\n  uf = (parts[1] || '').toUpperCase();\n}\n\nlet query = '';\nif (city && uf) {\n  query = `${city},${uf},BR`;\n} else if (city) {\n  query = `${city},BR`;\n}\n\nreturn [\n  {\n    queue: query,\n    cityNormalized: city,\n    uf,\n    chatId: $input.first().json.chatId,\n    originalText: raw\n  }\n];"
      },
