    {
      "parameters": {
        "jsCode": "const response = $json;\n\nconst status = response.cod ?? 0;\nconst main = response.main ?? {};\n\nconst ok =\n  status >= 200 &&\n  status < 300 &&\n  main &&\n  typeof main.temp === 'number';\n\nif (!ok) {\n  return [{\n    response: response,\n    status: status,\n    ok: false,\n    statusCode: status,\n    chatId: $('Edit Fields').first().json.chatId\n  }];\n}\n\nconst temp = main.temp;\nconst tempRounded = Math.round(temp);\nconst cityName = response.name;\n\nreturn [{\n  ok: true,\n  statusCode: status,\n  temp: temp,\n  tempRounded,\n  cityName,\n  chatId: $('Edit Fields').first().json.chatId\n}];"
      },
